# Normalize line endings so Windows checkouts don't keep churning files like
# public/sitemap.xml that are regenerated on every build.
* text=auto eol=lf

# Force LF for files generated by tooling
*.xml      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.toml     text eol=lf
*.sh       text eol=lf

# Windows-only scripts keep CRLF
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf

# Treat binaries as binary (no line-ending conversion, no diff noise)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.svg      text eol=lf
*.ico      binary
*.mp3      binary
*.mp4      binary
*.mov      binary
*.pdf      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
*.zip      binary
