# J. Worden & Sons Public Site — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local or .env to source control.

# ── Frontend (Vite) ─────────────────────────────────────────────────
# Base URL for the FastAPI backend (no trailing slash)
VITE_API_BASE_URL=https://your-backend.railway.app

# Canonical site URL — used in Schema.org and OG tags (no trailing slash)
VITE_SITE_URL=https://jwordenasphaltpaving.com

# Google Analytics 4 Measurement ID
VITE_GA4_ID=G-XXXXXXXXXX

# Google Place ID — used for the "Leave a Review" link on the Reviews page
VITE_GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxxxxxx

# Frontend auth mode
# none   = disable route guards (temporary build phase)
# strict = enforce RequireAuth on internal routes
VITE_AUTH_MODE=none

# Internal strategy panel mode (Command Center only)
# off    = hide strategy/competitor intelligence panels
# on     = show strategy panels, but only on /command-center route
VITE_INTERNAL_STRATEGY_MODE=off

# ── Backend (FastAPI) ────────────────────────────────────────────────
# Backend auth mode
# none   = bypass API auth checks (temporary build phase)
# strict = enforce bearer token/JWT/admin checks
AUTH_MODE=none

# Database connection — defaults to local SQLite if not set
# Production: DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./jworden_leads.db

# Long-lived master API key for internal tools (replaces hardcoded key)
JWORDEN_MASTER_KEY=change-me-to-a-long-random-secret

# JWT signing secret for client tokens
JWT_SECRET_KEY=another-long-random-secret

# ── Admin dashboard credentials ──────────────────────────────────────
# Protect the /admin routes.  ADMIN_PASSWORD is required — leave blank
# to disable the dashboard entirely.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# OpenAI API key — enables real GPT-4o Vision photo inspection
OPENAI_API_KEY=sk-...

# ElevenLabs API Key - enables high-end human-like voice synthesis
VITE_ELEVENLABS_API_KEY=your-elevenlabs-api-key
VITE_ELEVENLABS_VOICE_ID=pNInz6obpgH9PthW4RUI

# Google Gemini API key — use for Google-aligned workflows/content research
GEMINI_API_KEY=

# Perplexity API key — use for web-grounded research workflows
PERPLEXITY_API_KEY=

# Anthropic API key — use for Claude math/long-context workflows
ANTHROPIC_API_KEY=

# Optional Codex model override for file/code task routing
OPENAI_CODEX_MODEL=gpt-5.3-codex

# SMTP email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password

# Destination email(s) for new lead alerts (comma-separated)
NOTIFY_TO_EMAIL=owner@jworden.com

# Twilio SMS notifications (optional)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567
NOTIFY_TO_PHONE=+15559876543

# Additional CORS origins beyond the defaults (comma-separated)
EXTRA_CORS_ORIGINS=https://my-staging-site.netlify.app

# ── Background tasks: Celery + Redis ────────────────────────────────────────
# Redis connection URL — used as Celery broker, result backend, and vision job queue
REDIS_URL=redis://localhost:6379/0
# Override result backend separately if needed (defaults to REDIS_URL)
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LangChain / Virtual Foreman RAG ─────────────────────────────────────────
# Same OPENAI_API_KEY above is reused for LangChain embeddings + LLM calls.
# Optionally persist the Chroma vector store to a directory:
# CHROMA_PERSIST_DIR=/data/chroma

# ── Vision inference (PyTorch / Cloud Run) ──────────────────────────────────
# URL of the Google Cloud Run PyTorch inference service (no trailing slash).
# Leave blank to use the local stub (development).
VISION_INFERENCE_URL=

# ── Virginia LIS permit scraper ──────────────────────────────────────────────
# API key for the Virginia DPOR permit data feed (optional — public queries work without it).
VIRGINIA_LIS_API_KEY=

# ── Business contact / location (Schema.org + JSON-LD) ───────────────
BUSINESS_PHONE=+18044461296
BUSINESS_EMAIL=contact@jwordenasphaltpaving.com
BUSINESS_STREET=1601 Ware Bottom Springs Rd Suite 214
BUSINESS_CITY=Chester
BUSINESS_STATE=VA
BUSINESS_ZIP=23836
BUSINESS_LAT=37.352900
BUSINESS_LNG=-77.432600
GOOGLE_MAPS_URL=https://www.google.com/maps/place/J.+Worden+%26+Sons+Asphalt+Paving
SITE_URL=https://jwordenasphaltpaving.com

# ── Social Media Profiles (Frontend — Vite) ─────────────────────────
# Override any platform URL to point to your real verified account.
# Defaults in src/lib/social.js are used when these are not set.
VITE_FACEBOOK_URL=https://www.facebook.com/JWordenSons
VITE_INSTAGRAM_URL=https://www.instagram.com/jwordensons
VITE_YOUTUBE_URL=https://www.youtube.com/@JWordenSons
VITE_LINKEDIN_URL=https://www.linkedin.com/company/jworden-sons
VITE_TWITTER_URL=https://twitter.com/JWordenSons
VITE_NEXTDOOR_URL=https://nextdoor.com/pages/jworden-sons-chester-va

# ── X + Grok Automation (Backend/Ops secrets only) ───────────────────
# Do NOT use VITE_ for these values.
# xAI (Grok) API key
XAI_API_KEY=

# X (Twitter) API credentials for read/post automation
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Command Center — Google Maps Platform ───────────────────────────
# Used for Solar API (takeoff/DSM data) and Aerial View API (3D video)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Frontend-exposed Maps key (loaded by @vis.gl/react-google-maps in the browser)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Optional provider status flags for Command Center health matrix ─────
# Values accepted: up/down, true/false, ready/check
VITE_PROVIDER_GEMINI_STATUS=
VITE_PROVIDER_PERPLEXITY_STATUS=
VITE_PROVIDER_CLAUDE_STATUS=
VITE_PROVIDER_CODEX_STATUS=
VITE_PROVIDER_GROK_STATUS=
VITE_PROVIDER_DROPBOX_STATUS=
VITE_PROVIDER_GPHOTOS_STATUS=
VITE_PROVIDER_X_STATUS=
VITE_PROVIDER_SENTRY_STATUS=

# ── Concierge WebGL Avatar (optional overrides) ─────────────────────
# No setup required: app auto-probes common paths and verifies model bytes.
# If no valid model is found, it falls back to a built-in procedural avatar.
# Override one URL:
# VITE_CONCIERGE_AVATAR_MODEL_URL=https://cdn.yoursite.com/models/mr-worden.glb
# Or provide priority list (comma-separated):
# VITE_CONCIERGE_AVATAR_MODEL_URLS=https://cdn1/model.glb,https://cdn2/model.glb
# Render quality: low | medium | high | ultra | cinematic | max
VITE_CONCIERGE_AVATAR_RENDER_QUALITY=max
# Optional: real-photo fallback shown when a valid 3D model is unavailable
# Example: VITE_CONCIERGE_AVATAR_POSTER_URL=https://cdn.yoursite.com/founder-portrait.jpg
VITE_CONCIERGE_AVATAR_POSTER_URL=
# Avatar realism mode:
# photo  = always use real portrait imagery (recommended for conversion)
# hybrid = use 3D model only when model is valid, otherwise portrait image
VITE_CONCIERGE_AVATAR_REALISM_MODE=photo
VITE_CONCIERGE_AVATAR_MODEL_URL=
VITE_CONCIERGE_AVATAR_MODEL_URLS=

# ── Command Center — Virginia Permitting APIs ────────────────────────
# Virginia Permit Transparency base URL (defaults shown; override if needed)
VPT_ENDPOINT=https://permits.virginia.gov/api

# Virginia DEQ PEEP tracking base URL
DEQ_PEEP_ENDPOINT=https://www.deq.virginia.gov/api/peep

# Apify API token — used to query DPOR license scraper
APIFY_TOKEN=your-apify-api-token

# ── Feature 4: Follow-up Task Queue (Celery) ────────────────────────
# Celery broker URL — defaults to REDIS_URL if not set.
CELERY_BROKER_URL=redis://localhost:6379/1

# How often the follow-up beat scheduler checks for due tasks (minutes)
FOLLOWUP_CHECK_INTERVAL_MINUTES=15

# Celery result backend — defaults to REDIS_URL if not set.
CELERY_RESULT_BACKEND=

# ── Feature 5: Proposal Generator ───────────────────────────────────
# Sender name used in proposal email footers
PROPOSAL_SENDER_NAME=J. Worden & Sons Asphalt Paving

# ── Feature 6: National Permit Scrapers ─────────────────────────────
# NYC Open Data API token (optional — increases rate limits)
NYC_OPENDATA_APP_TOKEN=your-nyc-opendata-token

# ── Feature 7: Material Price Index (EIA) ───────────────────────────
# EIA (U.S. Energy Information Administration) API key
# Free registration at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key

# ── Feature 8: Weather Service (OpenWeatherMap) ─────────────────────
# OpenWeatherMap API key — used for paving weather forecasts
# Free tier at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ── Feature 13: Market Intelligence (Google Places) ─────────────────
# Google Places API key for competitor radius searches
# Uses the same GOOGLE_MAPS_API_KEY above — no separate key needed

# ── Command Center — Edge-level PIN gate (PRIMARY protection) ────────────
# Enforced server-side by the Netlify Edge Function (netlify/edge-functions/
# command-center-auth.ts) BEFORE the SPA bundle is served.  This value is
# NEVER exposed to the browser.
#
# Set this in Netlify UI → Site → Environment variables.
# Leave blank (or omit) to block /command-center entirely (503 response).
#
# Example: COMMAND_CENTER_PIN=1025
COMMAND_CENTER_PIN=1234

# Command Center Edge auth mode
# none   = bypass edge PIN gate
# strict = enforce COMMAND_CENTER_PIN gate
COMMAND_CENTER_AUTH_MODE=none

# ── Command Center login guard (SECONDARY client-side deterrent) ─────────
# ⚠️  CLIENT-SIDE ONLY — NOT real security.
# VITE_ variables are compiled into the browser JavaScript bundle and are
# visible to anyone who inspects the page source.  This PIN gate is a
# convenience deterrent only; the Edge Function above is the real boundary.
#
# Set to a non-empty string to show the PIN gate on /command-center.
# If left blank (or not set), the page shows a "Not Available" notice and
# the gate is disabled — it will NEVER auto-unlock.
VITE_CC_PASSWORD=your-secret-pin

# Default tenant ID for single-tenant / legacy deployments
DEFAULT_TENANT_ID=default

# ── Observability (Sentry) ───────────────────────────────────────────
# Sentry DSN — leave blank to disable error tracking. When set, must be a real DSN.
SENTRY_DSN=

# Fraction of transactions to sample for performance tracing (0.0–1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1


# Do not expose JWORDEN_MASTER_KEY or other backend/admin secrets with a VITE_ prefix.
# Do not set VITE_MASTER_API_KEY; any VITE_ value is visible in the browser.
# Vite variables are bundled into browser JavaScript and visible to site visitors.

# Toggle runtime schema auto-create (set false in production when using Alembic)
AUTO_CREATE_TABLES=true

# Resend transactional email (preferred over raw SMTP)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=JWordenAI <notifications@yourdomain.com>

# ── SendGrid transactional email ─────────────────────────────────────
# Used by app/services/email_service.py and app/routers/email.py.
# Leave SENDGRID_API_KEY blank to disable SendGrid sends (graceful degrade).
# Note: this stack co-exists with Resend above; consolidation is pending.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=J. Worden & Sons Asphalt Paving

# ── Pinecone vector search ───────────────────────────────────────────
# Required by app/services/vector_search_service.py for semantic search /
# RAG features. Leave blank to disable vector search.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# ── Elasticsearch full-text search ───────────────────────────────────
# Powers /api/v1/search. Leave ELASTICSEARCH_HOST blank/unset to disable
# search features (router still mounts and returns empty results).
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# ── Datadog metrics + Slack alerting ─────────────────────────────────
# Both are optional; the monitoring service degrades silently when unset.
DATADOG_API_KEY=
SLACK_WEBHOOK_URL=

# ── Google Places (live reviews) ─────────────────────────────────────
# When set, /api/v1/reviews can be wired to the Places Details API.
# Currently the endpoint serves curated stub data and logs a warning
# when this key is not set. See app/routers/reviews.py.
GOOGLE_PLACES_API_KEY=

# ── Virginia LIS scraper toggle ──────────────────────────────────────
# The Virginia LIS scraper currently has only a stub implementation that
# returns synthetic permit rows. Set this to "true" ONLY in dev to
# exercise the pipeline. In production, leave blank/false so the Celery
# beat job is a no-op until a real scraper is wired.
ENABLE_LIS_SCRAPER_STUB=false

# ── Gunicorn worker count cap (production) ───────────────────────────
# Without this, gunicorn.conf.py uses (2 * cpu_count + 1) which can
# exhaust managed Postgres connection limits when multiplied by
# DB_POOL_SIZE. Set explicitly on small/managed instances (e.g. 3).
WEB_CONCURRENCY=

# ── LangSmith AI observability ───────────────────────────────────────
# When LANGSMITH_TRACING_V2=true, every OpenAI call is traced in the
# LangSmith dashboard (smith.langchain.com). Leave unset in dev/CI to
# silence tracing. Requires: pip install langsmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=jworden-ai
LANGSMITH_TRACING_V2=false

# ── Kickserv field-service integration ──────────────────────────────
# Kickserv API key (Account Settings → API Access in your Kickserv portal).
# KICKSERV_ACCOUNT is the account slug from your Kickserv URL.
# Used by: GET /api/v1/kickserv/jobs, POST /api/v1/kickserv/optimize-route
KICKSERV_API_KEY=
KICKSERV_ACCOUNT=
KICKSERV_BASE_URL=https://api.kickserv.com/v1

# ── Google Ads reporting ──────────────────────────────────────────────
# Required for live data in GET /api/v1/google-reporting/summary
# Without these the endpoint returns clearly-labelled stub data.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── Google Search Console reporting ──────────────────────────────────
# GOOGLE_SEARCH_CONSOLE_SERVICE_ACCOUNT_JSON — full JSON key for a
# service account with Search Console Read & Analyze permission.
# GOOGLE_SEARCH_CONSOLE_SITE_URL — e.g. sc-domain:jwordenasphaltpaving.com
GOOGLE_SEARCH_CONSOLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SEARCH_CONSOLE_SITE_URL=

# ── Google Analytics 4 (backend data API) ────────────────────────────
# Numeric GA4 property ID (found in GA4 → Admin → Property Settings).
# Used by the unified reporting endpoint; the frontend uses VITE_GA4_ID.
GOOGLE_ANALYTICS_PROPERTY_ID=

# ── Capacitor mobile build ────────────────────────────────────────────
# Set when building the iOS/Android app targets.
# CAPACITOR_APP_ID must match capacitor.config.ts appId.
CAPACITOR_APP_ID=com.jwordenai.app
CAPACITOR_APP_NAME=JWordenAI


# Stripe payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://jwordenasphaltpaving.com/quote?payment=success
STRIPE_CANCEL_URL=https://jwordenasphaltpaving.com/quote?payment=cancel
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
