# J. Worden & Sons Public Site — Environment Variables
# Copy this file to .env.local for local development.
# NEVER commit .env.local or .env to source control.

# ── Frontend (Vite) ─────────────────────────────────────────────────
# Base URL for the FastAPI backend (no trailing slash)
VITE_API_BASE_URL=https://your-backend.railway.app

# Canonical site URL — used in Schema.org and OG tags (no trailing slash)
VITE_SITE_URL=https://jwordenasphaltpaving.com

# Google Analytics 4 Measurement ID
VITE_GA4_ID=G-XXXXXXXXXX

# Google Place ID — used for the "Leave a Review" link on the Reviews page
VITE_GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxxxxxx

# ── Backend (FastAPI) ────────────────────────────────────────────────
# Database connection — defaults to local SQLite if not set
# Production: DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./jworden_leads.db

# Long-lived master API key for internal tools (replaces hardcoded key)
JWORDEN_MASTER_KEY=change-me-to-a-long-random-secret

# JWT signing secret for client tokens
JWT_SECRET_KEY=another-long-random-secret

# ── Admin dashboard credentials ──────────────────────────────────────
# Protect the /admin routes.  ADMIN_PASSWORD is required — leave blank
# to disable the dashboard entirely.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# OpenAI API key — enables real GPT-4o Vision photo inspection
OPENAI_API_KEY=sk-...

# SMTP email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password

# Destination email(s) for new lead alerts (comma-separated)
NOTIFY_TO_EMAIL=owner@jworden.com

# Twilio SMS notifications (optional)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567
NOTIFY_TO_PHONE=+15559876543

# Additional CORS origins beyond the defaults (comma-separated)
EXTRA_CORS_ORIGINS=https://my-staging-site.netlify.app

# ── Business contact / location (Schema.org + JSON-LD) ───────────────
BUSINESS_PHONE=+18044461296
BUSINESS_EMAIL=contact@jwordenasphaltpaving.com
BUSINESS_STREET=1601 Ware Bottom Springs Rd Suite 214
BUSINESS_CITY=Chester
BUSINESS_STATE=VA
BUSINESS_ZIP=23836
BUSINESS_LAT=37.352900
BUSINESS_LNG=-77.432600
GOOGLE_MAPS_URL=https://www.google.com/maps/place/J.+Worden+%26+Sons+Asphalt+Paving
SITE_URL=https://jwordenasphaltpaving.com

# ── Social Media Profiles (Frontend — Vite) ─────────────────────────
# Override any platform URL to point to your real verified account.
# Defaults in src/lib/social.js are used when these are not set.
VITE_FACEBOOK_URL=https://www.facebook.com/JWordenSons
VITE_INSTAGRAM_URL=https://www.instagram.com/jwordensons
VITE_YOUTUBE_URL=https://www.youtube.com/@JWordenSons
VITE_LINKEDIN_URL=https://www.linkedin.com/company/jworden-sons
VITE_TWITTER_URL=https://twitter.com/JWordenSons
VITE_NEXTDOOR_URL=https://nextdoor.com/pages/jworden-sons-chester-va

# ── Command Center — Google Maps Platform ───────────────────────────
# Used for Solar API (takeoff/DSM data) and Aerial View API (3D video)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Frontend-exposed Maps key (loaded by @vis.gl/react-google-maps in the browser)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Command Center — Virginia Permitting APIs ────────────────────────
# Virginia Permit Transparency base URL (defaults shown; override if needed)
VPT_ENDPOINT=https://permits.virginia.gov/api

# Virginia DEQ PEEP tracking base URL
DEQ_PEEP_ENDPOINT=https://www.deq.virginia.gov/api/peep

# Apify API token — used to query DPOR license scraper
APIFY_TOKEN=your-apify-api-token

# ── Feature 1: Conversation Memory (Redis) ──────────────────────────
# Redis URL — enables multi-turn chat memory and distributed caching.
# Falls back to SQLite ChatSession table when not set.
REDIS_URL=redis://localhost:6379/0

# ── Feature 4: Follow-up Task Queue (Celery) ────────────────────────
# Celery broker URL — defaults to REDIS_URL if not set.
CELERY_BROKER_URL=redis://localhost:6379/1

# How often the follow-up beat scheduler checks for due tasks (minutes)
FOLLOWUP_CHECK_INTERVAL_MINUTES=15

# ── Feature 5: Proposal Generator ───────────────────────────────────
# Sender name used in proposal email footers
PROPOSAL_SENDER_NAME=J. Worden & Sons Asphalt Paving

# ── Feature 6: National Permit Scrapers ─────────────────────────────
# NYC Open Data API token (optional — increases rate limits)
NYC_OPENDATA_APP_TOKEN=your-nyc-opendata-token

# ── Feature 7: Material Price Index (EIA) ───────────────────────────
# EIA (U.S. Energy Information Administration) API key
# Free registration at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key

# ── Feature 8: Weather Service (OpenWeatherMap) ─────────────────────
# OpenWeatherMap API key — used for paving weather forecasts
# Free tier at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ── Feature 13: Market Intelligence (Google Places) ─────────────────
# Google Places API key for competitor radius searches
# Uses the same GOOGLE_MAPS_API_KEY above — no separate key needed

# ── Command Center login guard ───────────────────────────────────────
# Set to a non-empty string to password-protect /command-center in the frontend.
# Leave blank (default) to disable the gate — useful during local development.
VITE_CC_PASSWORD=your-secret-pin

# Default tenant ID for single-tenant / legacy deployments
DEFAULT_TENANT_ID=default

# ── Observability (Sentry) ───────────────────────────────────────────
# Sentry DSN — leave blank to disable error tracking
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYYY

# Fraction of transactions to sample for performance tracing (0.0–1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
